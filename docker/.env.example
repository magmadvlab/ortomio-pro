# Supabase Local Development - Environment Variables
# Copia questo file come .env e modifica i valori

# Database Password (usa una password forte)
POSTGRES_PASSWORD=your-super-secret-password-change-this

# JWT Secret (deve essere almeno 32 caratteri)
# Genera una chiave sicura: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long-change-this

# JWT Expiration (in secondi, default 3600 = 1 ora)
JWT_EXP=3600

# API Keys (generate automaticamente da JWT_SECRET)
# Queste verranno generate, ma puoi sovrascriverle se necessario
ANON_KEY=
SERVICE_ROLE_KEY=
