{
  "name": "ortomio-ai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev -H localhost -p 3002",
    "dev:next": "next dev -p 3002",
    "dev:port": "next dev -p",
    "build": "next build",
    "build:next": "next build",
    "start": "next start -p 3002",
    "start:next": "next start -p 3002",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "check": "npm run type-check && npm run build",
    "lint": "echo 'Linter check skipped - ESLint not configured' || true",
    "pre-deploy": "node scripts/pre-deploy-check.js",
    "pre-deploy:fast": "node scripts/pre-deploy-check.js --skip-build",
    "pre-commit": "npm run pre-deploy",
    "generate:plant-migration": "tsx scripts/generatePlantTaxonomyMigration.ts",
    "apply:plant-migration": "tsx scripts/applyPlantTaxonomyMigration.ts",
    "test:health-check": "tsx scripts/test-health-check.ts"
  },
  "dependencies": {
    "@capacitor/core": "^5.5.1",
    "@capacitor/filesystem": "^5.1.4",
    "@google/genai": "^1.31.0",
    "@google/generative-ai": "^0.24.1",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.87.1",
    "@types/pdfkit": "^0.17.4",
    "date-fns": "^4.1.0",
    "exif-js": "^2.3.0",
    "lucide-react": "^0.556.0",
    "next": "^16.0.8",
    "next-pwa": "^5.6.0",
    "pdfkit": "^0.17.2",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "recharts": "^3.6.0",
    "stripe": "^20.0.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^24.10.3",
    "@types/pg": "^8.16.0",
    "@types/react": "19.2.7",
    "@types/recharts": "^1.8.29",
    "autoprefixer": "^10.4.22",
    "pg": "^8.16.3",
    "postcss": "^8.5.6",
    "server-only": "^0.0.1",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
