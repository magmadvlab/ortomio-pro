{
  "name": "ortomio-ai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev -H localhost -p 3002",
    "dev:turbo": "next dev -H localhost -p 3002",
    "dev:next": "next dev -p 3002",
    "dev:port": "next dev -p",
    "build": "next build --webpack",
    "build:next": "next build --webpack",
    "start": "next start -p 3002",
    "start:next": "next start -p 3002",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "check": "npm run type-check && npm run build",
    "lint": "echo 'Linter check skipped - ESLint not configured' || true",
    "pre-deploy": "node scripts/pre-deploy-check.js",
    "pre-deploy:fast": "node scripts/pre-deploy-check.js --skip-build",
    "pre-commit": "npm run pre-deploy",
    "generate:plant-migration": "tsx scripts/generatePlantTaxonomyMigration.ts",
    "apply:plant-migration": "tsx scripts/applyPlantTaxonomyMigration.ts",
    "test:health-check": "tsx scripts/test-health-check.ts",
    "test:precision-hub": "NODE_OPTIONS=--conditions=react-server npx --yes tsx --test __tests__/precision-hub/**/*.test.ts",
    "test:security": "NODE_OPTIONS=--conditions=react-server npx --yes tsx --test __tests__/security/**/*.test.ts",
    "test:capabilities": "NODE_OPTIONS=--conditions=react-server npx --yes tsx --test __tests__/capabilities/**/*.test.ts",
    "test:persistence": "NODE_OPTIONS=--conditions=react-server npx --yes tsx --test __tests__/persistence/**/*.test.ts",
    "test:physical-operations": "NODE_OPTIONS=--conditions=react-server npx --yes tsx --test __tests__/physical-operations/**/*.test.ts",
    "test:health-predictions-monitoring": "NODE_OPTIONS=--conditions=react-server npx --yes tsx --test __tests__/health-predictions-monitoring/**/*.test.ts",
    "test:remote-data-isolation": "NODE_OPTIONS=--conditions=react-server npx --yes tsx --test __tests__/remote-data-isolation/**/*.test.ts",
    "test:regulatory-exports-admin": "NODE_OPTIONS=--conditions=react-server npx --yes tsx --test __tests__/regulatory-exports-admin/**/*.test.ts",
    "test:rollout-observability": "NODE_OPTIONS=--conditions=react-server npx --yes tsx --test __tests__/rollout-observability/**/*.test.ts",
    "test:release": "npm run test:security && npm run test:capabilities && npm run test:persistence && npm run test:physical-operations && npm run test:health-predictions-monitoring && npm run test:remote-data-isolation && npm run test:regulatory-exports-admin && npm run test:rollout-observability && npm run test:precision-hub",
    "release:check": "node scripts/check-release-readiness.mjs",
    "release:check:remote": "node scripts/check-release-readiness.mjs --require-remote",
    "audit:p0": "node scripts/audit-p0-baseline.mjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@neondatabase/serverless": "^1.1.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.87.1",
    "@types/leaflet": "^1.9.21",
    "date-fns": "^4.1.0",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.556.0",
    "next": "^16.1.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.6.0",
    "server-only": "^0.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^24.10.3",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.22",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "typescript": "~5.8.2"
  }
}
